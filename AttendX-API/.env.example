# Copy this file to .env and fill in your values
# Never commit .env to git

# Get this from PostgreSQL — format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/attendx"

# Make this a long random string — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_this_with_a_long_random_secret_string"

# How long tokens last
JWT_EXPIRES_IN="7d"

# Port the server runs on
PORT=3000